{
  "displayName": "PMU Electoral Day D Dashboard",
  "mosaicLayout": {
    "columns": 24,
    "tiles": [
      {
        "width": 8,
        "height": 4,
        "xPos": 0,
        "yPos": 0,
        "widget": {
          "title": "SSE Active Connections (usuarios en línea)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"custom.googleapis.com/electoral/sse_active_connections\" AND resource.type=\"global\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_MEAN",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "thresholds": []
          }
        }
      },
      {
        "width": 8,
        "height": 4,
        "xPos": 8,
        "yPos": 0,
        "widget": {
          "title": "Requests — últimos 5 min",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" AND resource.type=\"cloud_run_revision\"",
                "aggregation": {
                  "alignmentPeriod": "300s",
                  "perSeriesAligner": "ALIGN_SUM",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "thresholds": []
          }
        }
      },
      {
        "width": 8,
        "height": 4,
        "xPos": 16,
        "yPos": 0,
        "widget": {
          "title": "Tasa de errores 5xx — últimos 5 min",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"run.googleapis.com/request_count\" AND resource.type=\"cloud_run_revision\" AND metric.label.response_code_class=\"5xx\"",
                "aggregation": {
                  "alignmentPeriod": "300s",
                  "perSeriesAligner": "ALIGN_RATE",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "thresholds": [
              { "value": 5, "color": "YELLOW", "direction": "ABOVE" },
              { "value": 10, "color": "RED", "direction": "ABOVE" }
            ]
          }
        }
      },

      {
        "width": 8,
        "height": 8,
        "xPos": 0,
        "yPos": 4,
        "widget": {
          "title": "Cloud SQL — Conexiones activas",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/network/connections\" AND resource.type=\"cloudsql_database\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Conexiones"
            }],
            "thresholds": [
              { "value": 20, "color": "YELLOW", "direction": "ABOVE", "label": "80% max" },
              { "value": 24, "color": "RED", "direction": "ABOVE", "label": "Crítico" }
            ]
          }
        }
      },
      {
        "width": 8,
        "height": 8,
        "xPos": 8,
        "yPos": 4,
        "widget": {
          "title": "Cloud SQL — CPU utilización",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/cpu/utilization\" AND resource.type=\"cloudsql_database\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "CPU %"
            }],
            "thresholds": [
              { "value": 0.8, "color": "YELLOW", "direction": "ABOVE" },
              { "value": 0.95, "color": "RED", "direction": "ABOVE" }
            ]
          }
        }
      },
      {
        "width": 8,
        "height": 8,
        "xPos": 16,
        "yPos": 4,
        "widget": {
          "title": "Cloud SQL — Almacenamiento (bytes)",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/disk/bytes_used\" AND resource.type=\"cloudsql_database\"",
                  "aggregation": {
                    "alignmentPeriod": "300s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Bytes usados"
            }]
          }
        }
      },

      {
        "width": 8,
        "height": 8,
        "xPos": 0,
        "yPos": 12,
        "widget": {
          "title": "Cloud Run — Instancias activas",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/instance_count\" AND resource.type=\"cloud_run_revision\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Instancias"
            }],
            "thresholds": [
              { "value": 4, "color": "YELLOW", "direction": "ABOVE" },
              { "value": 5, "color": "RED", "direction": "ABOVE", "label": "Max" }
            ]
          }
        }
      },
      {
        "width": 16,
        "height": 8,
        "xPos": 8,
        "yPos": 12,
        "widget": {
          "title": "Cloud Run — Latencia requests (p50/p95/p99 ms)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_50",
                      "crossSeriesReducer": "REDUCE_MAX"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "p50"
              },
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MAX"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "p95"
              },
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_99",
                      "crossSeriesReducer": "REDUCE_MAX"
                    }
                  }
                },
                "plotType": "LINE",
                "legendTemplate": "p99"
              }
            ],
            "thresholds": [
              { "value": 2000, "color": "YELLOW", "direction": "ABOVE", "label": "2s SLA" }
            ]
          }
        }
      },

      {
        "width": 12,
        "height": 8,
        "xPos": 0,
        "yPos": 20,
        "widget": {
          "title": "Requests por rol (último período)",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"custom.googleapis.com/electoral/api_requests_by_role\" AND resource.type=\"global\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_SUM",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": ["metric.labels.role"]
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "${metric.labels.role}"
            }]
          }
        }
      },
      {
        "width": 12,
        "height": 8,
        "xPos": 12,
        "yPos": 20,
        "widget": {
          "title": "Pool DB activo (requests in-flight)",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"custom.googleapis.com/electoral/db_pool_size\" AND resource.type=\"global\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "In-flight requests"
            }]
          }
        }
      },

      {
        "width": 12,
        "height": 8,
        "xPos": 0,
        "yPos": 28,
        "widget": {
          "title": "Mutaciones por recurso (últimos 60s)",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"custom.googleapis.com/electoral/mutation_count_by_resource\" AND resource.type=\"global\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_SUM",
                    "crossSeriesReducer": "REDUCE_SUM",
                    "groupByFields": ["metric.labels.resource"]
                  }
                }
              },
              "plotType": "STACKED_BAR",
              "legendTemplate": "${metric.labels.resource}"
            }]
          }
        }
      },
      {
        "width": 12,
        "height": 8,
        "xPos": 12,
        "yPos": 28,
        "widget": {
          "title": "Uptime check — disponibilidad",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"monitoring.googleapis.com/uptime_check/check_passed\" AND resource.type=\"uptime_url\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_FRACTION_TRUE",
                    "crossSeriesReducer": "REDUCE_MIN"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Uptime %"
            }],
            "thresholds": [
              { "value": 1, "color": "RED", "direction": "BELOW", "label": "Offline" }
            ]
          }
        }
      }
    ]
  }
}
