// Comando Electoral 2026 — data model.
// Canonical source: MIGRATION_SPEC.md §5, with DISCOVERY.md §5 Amendment 1
// (Comuna ⇄ Zona link). Prisma pinned to 6.x per Amendment 9.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl bypasses PgBouncer for Prisma migrations (migrate deploy needs a
  // direct connection; PgBouncer transaction mode blocks DDL advisory locks).
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  REGIONAL_COORDINATOR
  MUNICIPAL_COORDINATOR
  ZONE_COORDINATOR
  COMUNA_COORDINATOR
  PUESTO_COORDINATOR
  VIEWER
}

enum ScopeType {
  SUBREGION
  MUNICIPIO
  ZONA
  COMUNA
  PUESTO
}

model User {
  id                  Int       @id @default(autoincrement())
  username            String    @unique
  displayName         String
  phone               String?
  notes               String?
  role                Role
  active              Boolean   @default(true)
  cipUid              String    @unique
  mustChangePassword  Boolean   @default(true)
  createdAt           DateTime  @default(now())
  createdByUserId     Int?
  createdBy           User?     @relation("UserCreator", fields: [createdByUserId], references: [id])
  createdUsers        User[]    @relation("UserCreator")
  lastLoginAt         DateTime?
  scopes              UserScope[]
  testigosCreated     Testigo[]
  voluntariosCreated  Voluntario[]
  abogadosCreated     Abogado[]
  movilidadCreated    Movilidad[]
  refrigeriosCreated  Refrigerio[]
  comparendosCreated  Comparendo[]
  auditEntries            AuditLog[]
  prioridadConfigUpdates  PrioridadConfig[]

  @@index([active])
  @@index([role])
}

model UserScope {
  id        Int        @id @default(autoincrement())
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType ScopeType
  scopeId   Int

  @@unique([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
}

model Subregion {
  id                       Int         @id @default(autoincrement())
  name                     String      @unique
  municipios               Municipio[]
  coordinadorAdHocNombre   String?
  coordinadorAdHocTelefono String?
}

model Municipio {
  id                       Int        @id @default(autoincrement())
  subregionId              Int
  subregion                Subregion  @relation(fields: [subregionId], references: [id])
  name                     String
  divipola                 String     @unique
  coordinadorAdHocNombre   String?
  coordinadorAdHocTelefono String?
  comunas                  Comuna[]
  puestos                  Puesto[]
  abogados                 Abogado[]

  @@index([subregionId])
}

model Comuna {
  id                       Int          @id @default(autoincrement())
  municipioId              Int
  municipio                Municipio    @relation(fields: [municipioId], references: [id])
  name                     String
  zonaId                   Int?
  zona                     Zona?        @relation(fields: [zonaId], references: [id])
  coordinadorAdHocNombre   String?
  coordinadorAdHocTelefono String?
  coordinadorAdHocCedula   String?
  coordinadorAdHocCorreo   String?
  puestos                  Puesto[]
  voluntarios              Voluntario[]

  @@unique([municipioId, name])
  @@index([zonaId])
}

model Zona {
  id                       Int      @id @default(autoincrement())
  name                     String   @unique
  coordinadorAdHocNombre   String?
  coordinadorAdHocTelefono String?
  comunas                  Comuna[]
}

model Puesto {
  id                       Int              @id @default(autoincrement())
  municipioId              Int
  municipio                Municipio        @relation(fields: [municipioId], references: [id])
  comunaId                 Int?
  comuna                   Comuna?          @relation(fields: [comunaId], references: [id])
  divipola                 String           @unique
  name                     String
  address                  String
  lat                      Float
  lng                      Float
  mesas                    Int              @default(0)
  votantes                 Int              @default(0)
  tag                      String?
  notas                    String?
  coordinadorAdHocNombre    String?
  coordinadorAdHocTelefono  String?
  coordinadorAdHocCedula    String?
  coordinadorAdHocCorreo    String?
  coordinadorAdHocNombre2   String?
  coordinadorAdHocTelefono2 String?
  coordinadorAdHocCedula2   String?
  coordinadorAdHocCorreo2   String?
  testigos                  Testigo[]
  jurados                  Jurado[]
  prioridad                PuestoPrioridad?

  @@index([municipioId])
  @@index([comunaId])
}

model PuestoPrioridad {
  id              Int      @id @default(autoincrement())
  puestoId        Int      @unique
  puesto          Puesto   @relation(fields: [puestoId], references: [id], onDelete: Cascade)
  votosCreemos    Int      @default(0)
  votosSN         Int      @default(0)
  votosTotal      Int      @default(0)
  mesasHistoricas Int      @default(0)
  nivelPrioridad  String   @default("BAJA")
  notas           String?
  updatedAt       DateTime @updatedAt

  @@index([nivelPrioridad])
  @@index([votosTotal(sort: Desc)])
}

model PrioridadConfig {
  id              Int      @id @default(autoincrement())
  umbralAlto      Int      @default(500)
  umbralMedio     Int      @default(100)
  ratioMesasAlta  Float    @default(0.5)
  ratioMesasMedia Float    @default(0.4)
  ratioMesasBaja  Float    @default(0.33)
  updatedAt       DateTime @updatedAt
  updatedById     Int?
  updatedBy       User?    @relation(fields: [updatedById], references: [id])
}

model Testigo {
  id          Int      @id @default(autoincrement())
  puestoId    Int?
  puesto      Puesto?  @relation(fields: [puestoId], references: [id])
  name        String
  cedula      String?
  phone       String?
  correo      String?
  status      String   @default("pendiente")
  notes       String?
  mesaInicial Int?
  mesaFinal   Int?
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  token           String    @unique @default(uuid())
  confirmadoAt    DateTime?
  acreditadoAt    DateTime?
  enPuestoAt      DateTime?

  @@index([puestoId, id])
}

model Jurado {
  id              Int      @id @default(autoincrement())
  cedula          String   @unique
  nombre          String
  telefono        String?
  correo          String?
  puestoId        Int?
  puesto          Puesto?  @relation(fields: [puestoId], references: [id])
  puestoNombreCsv String?
  municipio       String
  estado          String   @default("confirmado")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([puestoId])
  @@index([municipio])
}

model Abogado {
  id          Int       @id @default(autoincrement())
  municipioId Int
  municipio   Municipio @relation(fields: [municipioId], references: [id])
  name        String
  phone       String?
  notes       String?
  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([municipioId])
}

model Movilidad {
  id           Int       @id @default(autoincrement())
  scopeType    ScopeType
  scopeId      Int
  vehicleType  String
  plate        String
  driverName   String
  driverPhone  String?
  notes        String?
  createdById  Int
  createdBy    User      @relation(fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([scopeType, scopeId])
}

model Refrigerio {
  id          Int       @id @default(autoincrement())
  scopeType   ScopeType
  scopeId     Int
  count       Int       @default(0)
  status      String    @default("pendiente")
  notes       String?
  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scopeType, scopeId])
}

model Comparendo {
  id          Int       @id @default(autoincrement())
  scopeType   ScopeType
  scopeId     Int
  date        DateTime
  description String
  status      String    @default("abierto")
  notes       String?
  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scopeType, scopeId])
}

model Voluntario {
  id          Int      @id @default(autoincrement())
  comunaId    Int
  comuna      Comuna   @relation(fields: [comunaId], references: [id])
  name        String
  cedula      String?
  phone       String?
  correo      String?
  rol         String?
  status      String   @default("activo")
  notes       String?
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([comunaId])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorUserId  Int
  actor        User     @relation(fields: [actorUserId], references: [id])
  action       String
  targetType   String
  targetId     Int?
  beforeJson   Json?
  afterJson    Json?
  ip           String?
  userAgent    String?
  ts           DateTime @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([ts])
}
