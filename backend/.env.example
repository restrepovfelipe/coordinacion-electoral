# Backend environment — placeholder twin of .env.local (which is gitignored).
# Copy to .env.local and fill in real values.
#
# Per DISCOVERY.md §5 Amendment 5, auth to GCP is keyless (ADC + service-account
# impersonation) — there is intentionally NO GOOGLE_APPLICATION_CREDENTIALS entry.

# Production (Cloud Run + PgBouncer sidecar):
#   DATABASE_URL     → PgBouncer on localhost:5432 (Prisma queries)
#   DIRECT_DATABASE_URL → Cloud SQL socket directly (realtime LISTEN, migrations)
#
# Local dev (Cloud SQL Auth Proxy on localhost:5432, no PgBouncer):
#   Both can be the same value.
DATABASE_URL=postgresql://app_user:REPLACE_WITH_URL_ENCODED_DB_PASSWORD@localhost:5432/defensores?pgbouncer=true&statement_cache_size=0
DIRECT_DATABASE_URL=postgresql://app_user:REPLACE_WITH_URL_ENCODED_DB_PASSWORD@localhost:5432/defensores

# Cloud SQL instance connection name (used by entrypoint.sh to configure PgBouncer).
# Format: PROJECT:REGION:INSTANCE
DB_INSTANCE_CONN=coordinacion-electoral:us-central1:defensores-pg

# Raw DB password (no URL-encoding) — used by entrypoint.sh to configure PgBouncer.
# In Cloud Run this is injected from the DB_APP_USER_PASSWORD Secret Manager secret.
DB_APP_USER_PASSWORD=REPLACE_WITH_DB_PASSWORD

GCP_PROJECT_ID=coordinacion-electoral
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5500,http://localhost:3000
